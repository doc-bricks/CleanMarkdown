{
  "name": "cleanmarkdown-companion",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Web/PWA Companion für CleanMarkdown (Vite + React + TS + Tailwind + Capacitor)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "node --test tests/pwa.test.mjs tests/stats.test.mjs tests/capacitor.test.mjs tests/android-doctor.test.mjs",
    "test:cap": "node --test tests/capacitor.test.mjs",
    "test:android-doctor": "node --test tests/android-doctor.test.mjs",
    "cap:doctor": "node --test tests/capacitor.test.mjs",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "android:doctor": "node scripts/android-doctor.mjs",
    "android:doctor:json": "node scripts/android-doctor.mjs --json --allow-blockers",
    "android:gradle-doctor": "node scripts/android-doctor.mjs --gradle"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "dompurify": "^3.4.12",
    "marked": "^15.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1"
  }
}
